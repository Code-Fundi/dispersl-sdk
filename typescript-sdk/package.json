{
  "name": "@dispersl/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for the Dispersl API - an agentic workflow platform for AI-driven software development",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepare": "cd .. && husky typescript-sdk/.husky || true",
    "prepublishOnly": "npm run clean && npm run build",
    "pre-commit": "npm run lint && npm run type-check && npm run test:unit",
    "pre-push": "npm run build && npm run test:coverage",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:unit:watch": "jest tests/unit --watch",
    "test:unit:coverage": "jest tests/unit --coverage",
    "test:integration": "RUN_INTEGRATION_TESTS=true jest tests/integration --detectOpenHandles",
    "test:integration:watch": "RUN_INTEGRATION_TESTS=true jest tests/integration --watch --detectOpenHandles",
    "test:e2e": "RUN_INTEGRATION_TESTS=true jest tests/e2e --detectOpenHandles",
    "test:e2e:watch": "RUN_INTEGRATION_TESTS=true jest tests/e2e --watch --detectOpenHandles",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:all:watch": "npm run test:unit:watch",
    "test:all:coverage": "npm run test:unit:coverage",
    "test:deploy": "npm run test:integration && npm run test:e2e",
    "test:deploy:ci": "RUN_INTEGRATION_TESTS=true jest tests/integration tests/e2e --detectOpenHandles --ci --coverage --watchAll=false",
    "test:client": "jest tests/unit/client.test.ts",
    "test:http": "jest tests/unit/http.test.ts",
    "test:auth": "jest tests/unit/auth.test.ts",
    "test:serializers": "jest tests/unit/serializers.test.ts",
    "test:agentic": "jest tests/unit/agentic.test.ts",
    "test:retry": "jest tests/unit/retry.test.ts",
    "test:workflows": "RUN_INTEGRATION_TESTS=true jest tests/integration/workflow.integration.test.ts",
    "test:api": "RUN_INTEGRATION_TESTS=true jest tests/integration/api.integration.test.ts",
    "test:complete": "RUN_INTEGRATION_TESTS=true jest tests/e2e/complete.workflows.test.ts"
  },
  "keywords": [
    "ai",
    "workflow",
    "agentic",
    "sdk",
    "api",
    "typescript",
    "javascript"
  ],
  "author": "Dispersl Team <support@dispersl.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/code-fundi/dispersl-sdk.git",
    "directory": "typescript-sdk"
  },
  "bugs": {
    "url": "https://github.com/code-fundi/dispersl-sdk/issues"
  },
  "homepage": "https://dispersl.com",
  "dependencies": {
    "axios": "^1.6.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "axios-mock-adapter": "^2.1.0",
    "eslint": "^8.0.0",
    "husky": "^9.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
